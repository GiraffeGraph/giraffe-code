{
  "name": "giraffe-code",
  "version": "0.2.23-alpha",
  "description": "Hierarchical multi-agent AI orchestration — run Claude, Codex, Gemini and more in sequence from a single CLI",
  "type": "module",
  "bin": {
    "giraffe": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "files": [
    "dist",
    "config",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0 <25"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "orchestration",
    "cli",
    "claude",
    "codex",
    "gemini",
    "langgraph",
    "coding-assistant"
  ],
  "author": {
    "name": "Yahya Efe Kuruçay",
    "email": "efekurucay24@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GiraffeGraph/giraffe-code.git"
  },
  "homepage": "https://github.com/GiraffeGraph/giraffe-code#readme",
  "bugs": {
    "url": "https://github.com/GiraffeGraph/giraffe-code/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "ink": "^5.0.0",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
